{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["bun-types", "vitest/globals"],
		"jsx": "react-jsx",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"noPropertyAccessFromIndexSignature": true,
		"verbatimModuleSyntax": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"outDir": "dist",
		"rootDir": ".",
		"baseUrl": ".",
		"paths": {
			"@shared/*": ["shared/*"],
			"@server/*": ["server/*"],
			"@/*": ["src/*"]
		}
	},
	"include": ["src", "server", "shared", "vite.config.ts"],
	"exclude": [
		"node_modules",
		"dist",
		"src/routes/blog.tsx",
		"src/routes/blog.$slug.tsx",
		"src/routes/journal.tsx",
		"src/routes/journal.$date.tsx",
		"src/routes/projects.tsx",
		"src/routes/projects.$name.tsx",
		"src/routes/calendar.tsx",
		"src/routes/publish.tsx",
		"src/__tests__/Journal.test.tsx",
		"src/__tests__/Publish.test.tsx"
	]
}
